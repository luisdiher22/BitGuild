# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Railway managed in production)
DATABASE_URL="postgresql://user:password@localhost:5432/demo1"

# ─── Redis ────────────────────────────────────────────────────────────────────
# Redis connection string (Railway managed in production)
REDIS_URL="redis://localhost:6379"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ─── GitHub OAuth (wired in Story 1.3) ───────────────────────────────────────
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ─── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=""

# ─── PostHog ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ─── Stripe (wired in Story 5.1) ──────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ─── TOTP encryption (Story 6.4) ──────────────────────────────────────────────
TOTP_ENCRYPTION_KEY=""

# ─── Skip env validation (CI/CD build without real secrets) ───────────────────
# SKIP_ENV_VALIDATION=true
